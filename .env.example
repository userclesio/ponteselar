# Renomeie para .env.local em testes locais.
# Na Vercel, configure em Settings > Environment Variables.
# NUNCA faca commit deste arquivo preenchido com valores reais.

# Chave de API do Selar (REGENERE a antiga que foi exposta!)
SELAR_API_KEY=coloque_a_chave_nova_aqui

# Credencial de API gerada na UTMify
UTMIFY_API_TOKEN=coloque_o_token_da_utmify_aqui

# Segredo para proteger o endpoint /api/sync (invente uma string longa e aleatoria)
CRON_SECRET=invente_uma_string_aleatoria_longa
